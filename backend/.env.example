# ============================================================================
# WrapperStandalone Backend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
SERVICE_NAME=wrapper-backend
LOG_LEVEL=info
DISABLE_LOGGING=false
BACKEND_VERBOSE_LOGS=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/wrapper
DB_POOL_SIZE=10
APP_POOL_SIZE=10
SYSTEM_POOL_SIZE=5
# Tenant-scoped requests reserve a connection for their full lifetime so RLS
# GUCs bind to the same connection as the query (see db/request-connection.ts).
# Default app pool raised to 50 to keep headroom; tune up if request latency
# is dominated by pool waits. Postgres handles hundreds of connections; 50 is
# conservative.
DB_POOL_MAX=50
DB_SYSTEM_POOL_MAX=15

# ── Authentication (Kinde) ───────────────────────────────────────────────────
KINDE_DOMAIN=https://your-app.kinde.com
KINDE_CLIENT_ID=your_client_id
KINDE_CLIENT_SECRET=your_client_secret
KINDE_M2M_CLIENT_ID=your_m2m_client_id
KINDE_M2M_CLIENT_SECRET=your_m2m_client_secret
KINDE_REDIRECT_URI=http://localhost:3000/api/auth/callback
KINDE_LOGOUT_REDIRECT_URI=http://localhost:3001
KINDE_MANAGEMENT_AUDIENCE=https://your-app.kinde.com/api
KINDE_MANAGEMENT_SCOPES=

# ── JWT / Sessions ───────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
# Optional: previous HS256 secret kept active during rotation
# Comma-separated list of old secrets to accept during rotation. Remove after 24h.
JWT_SECRET_PREVIOUS=
SESSION_SECRET=change-this-to-a-strong-random-secret
OPERATIONS_JWT_SECRET=
SHARED_APP_JWT_SECRET=
BCRYPT_ROUNDS=10

# ── Service JWT Signing (asymmetric, optional) ──────────────────────────────
# Defaults to HS256 with JWT_SECRET above — symmetric, identical to today.
# Set JWT_SIGNING_ALG=RS256 along with a PEM keypair to opt in to asymmetric
# signing. Downstreams (CRM, FA) can fetch the public key from
# GET /.well-known/jwks.json. See backend/docs/JWT_MIGRATION.md.
JWT_SIGNING_ALG=HS256
# PEM-encoded RSA private key. Multi-line values must escape newlines as \n.
JWT_PRIVATE_KEY=
# PEM-encoded RSA public key. Required when JWT_SIGNING_ALG=RS256.
JWT_PUBLIC_KEY=
# Identifier published as `kid` in the JWKS. Defaults to "wrapper-default".
JWT_KEY_ID=wrapper-default

# ── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
FRONTEND_DOMAIN=localhost:3001
BACKEND_URL=http://localhost:3000
BASE_URL=http://localhost:3000
BASE_DOMAIN=localhost
INVITATION_BASE_URL=http://localhost:3001
PROTOCOL=https

# ── App URLs (Business Suite) ────────────────────────────────────────────────
CRM_APP_URL=http://localhost:3002
HR_APP_URL=http://localhost:3003
AFFILIATE_APP_URL=http://localhost:3004
ACCOUNTING_APP_URL=http://localhost:3005
INVENTORY_APP_URL=http://localhost:3006
BUSINESS_SUITE_TARGET_APPS=crm,hr

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=800
RATE_LIMIT_WINDOW=900000

# ── File Uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=50000000
UPLOAD_DIR=uploads

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BYPASS_WEBHOOK_SIGNATURE=false

# Stripe Price IDs
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PROFESSIONAL_MONTHLY_PRICE_ID=
STRIPE_PROFESSIONAL_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=

# ── AWS ──────────────────────────────────────────────────────────────────────
# General credentials — used for Route 53 DNS management (DNS_MANAGEMENT IAM user)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_HOSTED_ZONE_ID=

# Dedicated messaging credentials — used for SNS/SQS/S3 (needs SNS:Publish, SQS:*, S3:PutObject/GetObject).
# If unset, falls back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above.
# Set these to a separate IAM user/role that has SNS:Publish on inter-app-events
# but does NOT have Route 53 permissions (least-privilege separation).
AWS_MESSAGING_ACCESS_KEY_ID=
AWS_MESSAGING_SECRET_ACCESS_KEY=

# ── SNS / SQS (Inter-App Messaging) ─────────────────────────────────────────
SNS_INTER_APP_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:inter-app-events
SNS_BROADCAST_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:inter-app-broadcast
SQS_WRAPPER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/wrapper-events
SQS_NOTIFICATIONS_IMMEDIATE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notifications-immediate
SQS_NOTIFICATIONS_BULK_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notifications-bulk
SQS_NOTIFICATIONS_SCHEDULED_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notifications-scheduled
# S3 claim-check bucket — only required when payloads exceed 200 KB (e.g. bulk-import onboarding snapshots)
# Leave empty to disable offloading (payloads stay inline in the message body)
SNS_LARGE_PAYLOAD_BUCKET=

# ── Email (Brevo / Sendinblue) ──────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@wrapper.app
BREVO_SENDER_NAME=Wrapper

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Temporal ─────────────────────────────────────────────────────────────────
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE_WRAPPER=wrapper-tasks

# ── AI Services ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Verification ─────────────────────────────────────────────────────────────
VERIFICATION_API_KEY=
VERIFICATION_API_SECRET=
VERIFICATION_API_VERSION=1.0.0
VERIFICATION_USE_LIVE=false

# ── DNS Management ───────────────────────────────────────────────────────────
SERVER_TARGET=

# ── Credits / Trial ──────────────────────────────────────────────────────────
DEFAULT_FREE_CREDITS=100
TRIAL_PERIOD_DAYS=14

# ── Supabase (if used) ──────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Wrapper Internal ─────────────────────────────────────────────────────────
WRAPPER_SECRET_KEY=
WRAPPER_ORG_CODE=
WRAPPER_API_URL=
WRAPPER_APP_CODE=
AUTH_TOKEN=
API_BASE_URL=
