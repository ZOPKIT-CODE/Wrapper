# ============================================================================
# WrapperStandalone Backend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
SERVICE_NAME=wrapper-backend
LOG_LEVEL=info
DISABLE_LOGGING=false
BACKEND_VERBOSE_LOGS=false

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local dev: a local Postgres (the value below). Staging/prod use AWS RDS, injected
# from Secrets Manager (zopkit/<env>/wrapper) — NOT Supabase. To point local dev at
# the staging RDS instead, open the SSM tunnel (deploy/ecs/db-tunnel.sh) and use a
# localhost:5432 URL with the role from zopkit/staging/rds-wrapper-roles.
DATABASE_URL=postgresql://user:password@localhost:5432/wrapper
DB_POOL_SIZE=10
APP_POOL_SIZE=10
SYSTEM_POOL_SIZE=5
# Tenant-scoped requests reserve a connection for their full lifetime so RLS
# GUCs bind to the same connection as the query (see db/request-connection.ts).
# Default app pool raised to 50 to keep headroom; tune up if request latency
# is dominated by pool waits. Postgres handles hundreds of connections; 50 is
# conservative.
DB_POOL_MAX=50
DB_SYSTEM_POOL_MAX=15

# ── Authentication (AWS Cognito — shared zopkit-platform pool) ──
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_6e8AY4eMj
COGNITO_CLIENT_ID=744sfndqk37c2eeq55k2c0oe10
COGNITO_DOMAIN=https://zopkit-platform-ay4emj.auth.us-east-1.amazoncognito.com
COGNITO_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_6e8AY4eMj
COGNITO_REDIRECT_URI=http://localhost:3000/api/auth/callback
COGNITO_LOGOUT_REDIRECT_URI=http://localhost:3001
# Cognito Admin APIs (user/org mgmt, P4) use AWS IAM creds, not an OAuth secret:
# AWS_REGION=us-east-1  (+ AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY or an instance role)
#
# PLATFORM-ADMIN plane (internal operators, cross-tenant). Membership of this
# Cognito group (surfaced via the cognito:groups token claim) marks a platform
# admin — NOT any tenant DB role. Provisioned in Terraform (aws_cognito_user_group).
COGNITO_PLATFORM_ADMIN_GROUP=platform-admins
# Break-glass ONLY: comma-separated emails treated as platform admins even without
# the group. Use to seat the first admin / recover, then empty it.
PLATFORM_ADMIN_BOOTSTRAP_EMAILS=

# ── JWT / Sessions ───────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
# Optional: previous HS256 secret kept active during rotation
# Comma-separated list of old secrets to accept during rotation. Remove after 24h.
JWT_SECRET_PREVIOUS=
SESSION_SECRET=change-this-to-a-strong-random-secret
OPERATIONS_JWT_SECRET=
SHARED_APP_JWT_SECRET=
BCRYPT_ROUNDS=10

# ── Service JWT Signing (asymmetric, optional) ──────────────────────────────
# Defaults to HS256 with JWT_SECRET above — symmetric, identical to today.
# Set JWT_SIGNING_ALG=RS256 along with a PEM keypair to opt in to asymmetric
# signing. Downstreams (CRM, FA) can fetch the public key from
# GET /.well-known/jwks.json. See backend/docs/JWT_MIGRATION.md.
JWT_SIGNING_ALG=HS256
# PEM-encoded RSA private key. Multi-line values must escape newlines as \n.
JWT_PRIVATE_KEY=
# PEM-encoded RSA public key. Required when JWT_SIGNING_ALG=RS256.
JWT_PUBLIC_KEY=
# Identifier published as `kid` in the JWKS. Defaults to "wrapper-default".
JWT_KEY_ID=wrapper-default

# ── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
FRONTEND_DOMAIN=localhost:3001
BACKEND_URL=http://localhost:3000
BASE_URL=http://localhost:3000
BASE_DOMAIN=localhost
INVITATION_BASE_URL=http://localhost:3001
PROTOCOL=https

# ── App URLs (Business Suite) ────────────────────────────────────────────────
CRM_APP_URL=http://localhost:3002
HR_APP_URL=http://localhost:3003
AFFILIATE_APP_URL=http://localhost:3004
ACCOUNTING_APP_URL=http://localhost:3005
INVENTORY_APP_URL=http://localhost:3006
BUSINESS_SUITE_TARGET_APPS=crm,hr

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=800
RATE_LIMIT_WINDOW=900000

# ── File Uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=50000000
UPLOAD_DIR=uploads

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BYPASS_WEBHOOK_SIGNATURE=false

# Stripe Price IDs
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PROFESSIONAL_MONTHLY_PRICE_ID=
STRIPE_PROFESSIONAL_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=

# ── AWS ──────────────────────────────────────────────────────────────────────
# General credentials — used for Route 53 DNS management (DNS_MANAGEMENT IAM user)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_HOSTED_ZONE_ID=

# Dedicated messaging credentials — used for SNS/SQS/S3 (needs SNS:Publish, SQS:*, S3:PutObject/GetObject).
# If unset, falls back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above.
# Set these to a separate IAM user/role that has SNS:Publish on inter-app-events
# but does NOT have Route 53 permissions (least-privilege separation).
AWS_MESSAGING_ACCESS_KEY_ID=
AWS_MESSAGING_SECRET_ACCESS_KEY=

# ── SNS / SQS (Inter-App Messaging) ─────────────────────────────────────────
SNS_INTER_APP_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:inter-app-events
SNS_BROADCAST_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:inter-app-broadcast
SQS_WRAPPER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/wrapper-events
SQS_NOTIFICATIONS_IMMEDIATE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notifications-immediate
SQS_NOTIFICATIONS_BULK_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notifications-bulk
SQS_NOTIFICATIONS_SCHEDULED_URL=https://sqs.us-east-1.amazonaws.com/123456789012/notifications-scheduled
# S3 claim-check bucket — only required when payloads exceed 200 KB (e.g. bulk-import onboarding snapshots)
# Leave empty to disable offloading (payloads stay inline in the message body)
SNS_LARGE_PAYLOAD_BUCKET=

# ── Email (Brevo / Sendinblue) ──────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@wrapper.app
BREVO_SENDER_NAME=Wrapper

# ── Shared cache: Redis / ElastiCache Valkey ──────────────────────────────────
# When REDIS_ENABLED=true, all auth caches (user/role/tenant-lookup) become a
# single shared tier in Valkey so invalidations propagate across all instances
# (required for correct permission revocation under horizontal scaling).
# When false/unreachable, falls back to an in-process Map (single instance only).
REDIS_ENABLED=false
# Preferred: a single connection URL. Use rediss:// for TLS (ElastiCache
# in-transit encryption). Cluster mode must be DISABLED for this single-endpoint client.
REDIS_URL=redis://localhost:6379
# Alternative to REDIS_URL — discrete settings (REDIS_TLS=true enables TLS):
# REDIS_HOST=my-valkey.xxxx.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=true

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Temporal ─────────────────────────────────────────────────────────────────
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE_WRAPPER=wrapper-tasks

# ── AI Services ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Verification ─────────────────────────────────────────────────────────────
VERIFICATION_API_KEY=
VERIFICATION_API_SECRET=
VERIFICATION_API_VERSION=1.0.0
VERIFICATION_USE_LIVE=false

# ── DNS Management ───────────────────────────────────────────────────────────
SERVER_TARGET=

# ── Credits / Trial ──────────────────────────────────────────────────────────
DEFAULT_FREE_CREDITS=100
TRIAL_PERIOD_DAYS=14

# (Supabase removed — wrapper uses AWS RDS for the DB, Cognito for auth, S3 for
# storage. These keys are no longer used.)

# ── Wrapper Internal ─────────────────────────────────────────────────────────
WRAPPER_SECRET_KEY=
WRAPPER_ORG_CODE=
WRAPPER_API_URL=
WRAPPER_APP_CODE=
AUTH_TOKEN=
API_BASE_URL=

# ── Observability: Sentry + OpenTelemetry ────────────────────────────────────
# Telemetry is OFF unless at least one of SENTRY_DSN / OTEL_EXPORTER_OTLP_ENDPOINT
# is set (see src/instrument.ts). Sentry owns the OpenTelemetry provider; when an
# OTLP endpoint is set the same (Sentry-sampled) spans are ALSO exported to it.
SENTRY_DSN=
# Trace sample rate in production (0..1). Dev/test always samples 100%.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Release identifier (defaults to package version). In CI/CD set to the git SHA.
SENTRY_RELEASE=
# OTLP/HTTP traces endpoint (base URL; "/v1/traces" is appended). In EKS this is
# the node-local OTel Collector agent, e.g. http://$(NODE_IP):4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# Logical service name used as the OTel resource service.name / Sentry "service" tag.
OTEL_SERVICE_NAME=wrapper-backend
