{
  "name": "wrapper-backend",
  "version": "1.0.0",
  "description": "Backend API for wrapper application",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bootstrap.ts",
    "start": "node dist/bootstrap.js",
    "start:dev": "tsx src/bootstrap.ts",
    "install:full": "rm -rf node_modules && pnpm install",
    "start:check": "node src/scripts/check-startup.mjs",
    "dev:check": "node src/scripts/check-startup.mjs",
    "test:db": "node src/scripts/test-db.mjs",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:cache": "vitest run --config vitest.cache.config.ts",
    "db:generate": "node -e \"console.error('db:generate is disabled — this repo uses a pg_dump baseline (no drizzle snapshot lineage). Create a migration with: pnpm db:new <name>, then pnpm db:schema:dump. See src/db/migrations/README.md'); process.exit(1)\"",
    "db:migrate": "node --import tsx src/db/run-migrations.ts",
    "db:new": "bash scripts/db/new-migration.sh",
    "db:baseline": "bash scripts/db/make-baseline.sh",
    "db:schema:dump": "WRITE=1 bash scripts/db/check-schema-drift.sh",
    "db:drift": "bash scripts/db/check-schema-drift.sh",
    "db:check:journal": "node scripts/db/check-journal.mjs",
    "db:check:prod-drift": "bash scripts/db/check-prod-drift.sh",
    "db:migrate:fa-entity-fields": "node src/db/migrations/scripts/run-fa-entity-fields-migration.js",
    "db:migrate:drop-credit-allocation-tables": "node src/db/migrations/scripts/run-credit-allocation-migration.js",
    "db:migrate:cleanup-tenant-data": "node src/db/migrations/scripts/cleanup-tenant-data-for-migration.js",
    "db:migrate:create-notification-templates": "node src/db/migrations/scripts/create-notification-templates-table.js",
    "db:migrate:create-external-applications": "node src/db/migrations/scripts/create-external-applications-table.js",
    "db:migrate:add-ui-customization": "node src/db/migrations/scripts/add-ui-customization-fields.js",
    "db:migrate:all": "bash src/db/migrations/scripts/run-all-migrations.sh",
    "db:check:registry": "node scripts/db/check-journal.mjs",
    "db:studio": "drizzle-kit studio",
    "db:push": "node --import tsx ./node_modules/drizzle-kit/bin.cjs push --config drizzle.config.dist.ts",
    "db:introspect": "drizzle-kit introspect",
    "delete-tenant": "node src/scripts/delete-tenant-data.js",
    "delete-all-tenants": "node src/scripts/delete-all-tenant-data.js",
    "reconcile-tenant-apps": "tsx src/scripts/reconcile-tenant-applications.ts",
    "reconcile-tenant-apps:dry-run": "tsx src/scripts/reconcile-tenant-applications.ts --dry-run",
    "sync-permissions": "tsx src/scripts/sync-permissions.js sync",
    "sync-permissions:validate": "tsx src/scripts/sync-permissions.js validate",
    "sync-permissions:summary": "tsx src/scripts/sync-permissions.js summary",
    "sync-permissions:dry-run": "tsx src/scripts/sync-permissions.js dry-run",
    "sync-permissions:app": "tsx src/scripts/sync-permissions.js app",
    "temporal:worker": "tsx temporal/worker.js",
    "temporal:start": "node temporal/start-workflow.js",
    "lint": "eslint src/",
    "ngrok": "ngrok http ${PORT:-3000}"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-cognito-identity-provider": "^3.1058.0",
    "@aws-sdk/client-route-53": "^3.700.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-sns": "^3.1024.0",
    "@aws-sdk/client-sqs": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.213.0",
    "@opentelemetry/instrumentation-aws-sdk": "0.68.0",
    "@opentelemetry/instrumentation-ioredis": "0.61.0",
    "@opentelemetry/sdk-trace-base": "2.6.1",
    "@sentry/node": "^10.46.0",
    "@temporalio/client": "^1.8.0",
    "@temporalio/worker": "^1.8.0",
    "@temporalio/workflow": "^1.8.0",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-code-block-lowlight": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-table": "^3",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/static-renderer": "^3.26.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^5.1.0",
    "ioredis": "^5.11.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "lowlight": "^3.3.0",
    "node-cron": "^4.1.0",
    "nodemailer": "^6.9.7",
    "openai": "^4.104.0",
    "pino": "^10.3.1",
    "pino-elasticsearch": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.3",
    "razorpay": "^2.9.6",
    "sanitize-html": "^2.17.4",
    "stripe": "^14.8.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.10",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
