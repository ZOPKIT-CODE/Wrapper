# ============================================================================
# WrapperStandalone Frontend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# All variables must be prefixed with VITE_ to be exposed to the client.
# ============================================================================

# ── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000

# ── Auth (AWS Cognito — shared zopkit-platform pool; Kinde->Cognito migration) ──
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_6e8AY4eMj
VITE_COGNITO_CLIENT_ID=744sfndqk37c2eeq55k2c0oe10
VITE_COGNITO_DOMAIN=https://zopkit-platform-ay4emj.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:3001/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:3001

# ── App Domains ──────────────────────────────────────────────────────────────
VITE_WRAPPER_DOMAIN=http://localhost:3001
VITE_CRM_DOMAIN=http://localhost:3002
VITE_CRM_CALLBACK_PATH=/callback
VITE_HR_APP_URL=http://localhost:3003
VITE_AFFILIATE_APP_URL=http://localhost:3004

# ── Assets ───────────────────────────────────────────────────────────────────
# Leave blank to use defaults (Cloudinary-hosted Zopkit logos)
VITE_LOGO_URL=
VITE_FULL_LOGO_URL=
# Onboarding sidebar / welcome (default: Cloudinary Zopkit-full PNG)
VITE_ONBOARDING_LOGO_URL=

# ── Secrets (client-side — avoid putting real secrets here) ──────────────────
VITE_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Environment ──────────────────────────────────────────────────────────────
VITE_ENV=development

# ── Observability: Sentry (browser) ──────────────────────────────────────────
# Frontend Sentry DSN (separate project from the backend). Telemetry is off when unset.
VITE_SENTRY_DSN=
# Prod trace sample rate (0..1); dev samples 100%.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Sourcemap upload (CI only — never commit a real token):
#   SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
