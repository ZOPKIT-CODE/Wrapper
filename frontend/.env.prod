# Production (ECS) build env: `vite build --mode prod`. Values inline into the bundle (public).
# Distinct from .env.production (legacy Kinde/EC2 build) — this targets the ECS prod stack
# on zopkit.com with Cognito auth. The API is a different origin than the SPA, so absolute
# URLs are required. Overrides the dev defaults in the base .env.
VITE_ENV=production
VITE_API_URL=https://api.zopkit.com/api
VITE_API_BASE_URL=https://api.zopkit.com
VITE_SENTRY_DSN=https://ddb79bc84a259a099662219432e073d5@o4511431284424704.ingest.us.sentry.io/4511513525288960
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
