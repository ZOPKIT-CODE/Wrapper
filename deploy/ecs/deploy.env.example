# Copy to deploy.env (gitignored) and fill in. Used by deploy-service.sh.
# These are environment-stable values — most come from `terraform output`.

# --- AWS / naming ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
NAME_PREFIX=zopkit-prod            # = <project>-<environment> (terraform local.name_prefix)

# --- Local paths to each app's repo root (the three sibling repos) ---
WRAPPER_REPO=/Users/you/Downloads/wrapper
CRM_REPO=/Users/you/Downloads/b2b-crm
FA_REPO=/Users/you/Downloads/finance-accounting

# --- Migration task networking (from `terraform output` / AWS) ---
# Use PUBLIC subnets + TASK_ASSIGN_PUBLIC_IP=ENABLED when there is no NAT
# (fargate_assign_public_ip=true). Use private subnets + DISABLED when behind NAT.
TASK_SUBNETS=subnet-aaa,subnet-bbb        # subnet ids, comma-separated
TASK_SG=sg-0123456789abcdef0              # the ECS task security group id
TASK_ASSIGN_PUBLIC_IP=ENABLED             # ENABLED (no NAT) | DISABLED (behind NAT)
ECS_CLUSTER=zopkit-staging-ecs            # optional; defaults to <name_prefix>-ecs

# --- Health URLs for the smoke test (optional but recommended) ---
WRAPPER_HEALTH_URL=https://api.yourdomain.com/health
CRM_HEALTH_URL=https://crm-api.yourdomain.com/health
FA_HEALTH_URL=https://accounting-api.yourdomain.com/api/health/health/live

# --- CRM / FA container specifics — VERIFY against those repos' Dockerfiles ---
# The wrapper values are confirmed; CRM/FA defaults are best-guess until checked.
# CRM_DOCKERFILE=server/Dockerfile
# CRM_TARGET=production
# CRM_MIGRATE_CMD=["node","dist/db/run-migrations.js"]
# FA_DOCKERFILE=server/Dockerfile
# FA_TARGET=production
# FA_MIGRATE_CMD=["node","dist/db/run-migrations.js"]
