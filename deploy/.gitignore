# Terraform — local working dirs & state (never commit)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfplan.bin
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform.tfvars        # holds account-specific values; commit terraform.tfvars.example instead

# Keep .terraform.lock.hcl committed (provider version pinning) — do NOT ignore it.

# Helm values rendered from terraform outputs (regenerated by scripts/render-values.sh)
helm/zopkit-backend/values-*.generated.yaml

# SES Lambda build artifact
terraform/.build/

# OS cruft
.DS_Store
